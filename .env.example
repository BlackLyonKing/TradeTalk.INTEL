# SUPABASE_URL: Your Supabase project URL
# Find this in Project Settings -> API
SUPABASE_URL="https://your-project-id.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: Required for server-side database access.
# Find this in Project Settings -> API (Service Role key)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# VAPI_SECRET: Optional secret to verify Vapi requests
VAPI_SECRET="your-vapi-secret-if-any"

# Stripe
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# Gemini
GEMINI_API_KEY="your-gemini-api-key"

# Vapi Client Configuration
VITE_VAPI_PUBLIC_KEY="your-vapi-public-key"
VITE_VAPI_ASSISTANT_ID="your-vapi-assistant-id"

# Coinglass
COINGLASS_API_KEY="your-coinglass-api-key"
